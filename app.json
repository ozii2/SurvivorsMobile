{
  "expo": {
    "name": "MyGame",
    "slug": "mygame",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": false
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oguzhan.mygame"
    },
    "android": {
      "package": "com.oguzhan.mygame",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "androidStatusBar": {
      "hidden": true,
      "translucent": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Oyunda avatar kullanmak için galeri erişimi gerekiyor."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c3b174ca-bc5c-48d8-8136-8f2c40c434f6"
      }
    },
    "owner": "oguzhankandemir"
  }
}
