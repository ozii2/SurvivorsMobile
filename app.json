{
  "expo": {
    "name": "Ball Survive",
    "slug": "mygame",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": false
    },
    "orientation": "portrait",
    "icon": "./assets/app_icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/app_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050510"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oguzhan.ballsurvive"
    },
    "android": {
      "package": "com.oguzhan.ballsurvive",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app_icon.png",
        "backgroundColor": "#050510",
        "monochromeImage": "./assets/app_icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "androidStatusBar": {
      "hidden": true,
      "translucent": true
    },
    "web": {
      "favicon": "./assets/app_icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Oyunda avatar kullanmak için galeri erişimi gerekiyor."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c3b174ca-bc5c-48d8-8136-8f2c40c434f6"
      }
    },
    "owner": "oguzhankandemir"
  }
}
